CXX := g++
CXXFLAGS := -std=c++17 -Wall -Wextra -pthread

.PHONY: all test clean

all: multi_chat_server_v2 multi_client

multi_chat_server_v2: multi_chat_server_v2.cc chat_common.h
	$(CXX) $(CXXFLAGS) multi_chat_server_v2.cc -o multi_chat_server_v2

multi_client: multi_client.cc
	$(CXX) $(CXXFLAGS) multi_client.cc -o multi_client

test: all
	python3 chat_advanced_integration_test.py

clean:
	rm -f multi_chat_server_v2 multi_client
