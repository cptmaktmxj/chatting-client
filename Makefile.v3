CXX := g++
CXXFLAGS := -std=c++17 -Wall -Wextra -pthread

.PHONY: all test clean

all: multi_chat_server_v3 multi_client

multi_chat_server_v3: multi_chat_server_v3.cc chat_common.h
	$(CXX) $(CXXFLAGS) multi_chat_server_v3.cc -o multi_chat_server_v3

multi_client: multi_client.cc
	$(CXX) $(CXXFLAGS) multi_client.cc -o multi_client

test: all
	python3 chat_advanced_v3_integration_test.py
	python3 chat_template_reaction_v3_test.py

clean:
	rm -f multi_chat_server_v3 multi_client
